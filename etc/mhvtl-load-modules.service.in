[Unit]
Description=Load mhvtl modules
Documentation=man:man:vtltape(1) man:man:vtllibrary(1)
Before=mhvtl.target
PartOf=mhvtl.target
Conflicts=shutdown.target
Before=shutdown.target

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=VTL_DEBUG="0"
Environment=MHVTL_BACKEND="mhvtl"
EnvironmentFile=-@CONF_PATH@/mhvtl.conf
ExecStart=/bin/sh -c 'case "$MHVTL_BACKEND" in tcmu*) modprobe target_core_user; modprobe tcm_loop;; *) modprobe mhvtl opts=$VTL_DEBUG;; esac; modprobe sg'

[Install]
WantedBy=mhvtl.target
